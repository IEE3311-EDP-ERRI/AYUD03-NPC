        Value         "3"
        Show          off
      }
      Parameter {
        Variable      "NumContStates"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "NumDiscStates"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "NumZCSignals"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "DirectFeedthrough"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "Ts"
        Value         "Ts"
        Show          off
      }
      Parameter {
        Variable      "TerminalBasedSampleTimes"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "Parameters"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "LangStandard"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "GnuExtensions"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "RuntimeCheck"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "HighlightLevel"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "Declarations"
        Value         "#include <math.h>\n"
"\n"
"// Error. \n"
"#define em_alpha InputSignal(0,0)\n"
"#define em_beta InputSignal(1,0)\n"
"\n"
"// Parameters.\n"
"#define Kp_p InputSignal(2,0)\n"
"#define Ki_p InputSignal(2,1)\n"
"#define w0_p InputSignal(2,2)\n"
"#define Ts_p InputSignal(2,3)\n"
"#define Vdc_p InputSignal(2,4)\n"
"#define pi 3.14159265359\n"
"\n"
"// Error.\n"
"float e_alpha;\n"
"float e_beta;\n"
"\n"
"// Parameters. \n"
"float Kp;\n"
"float Ki;\n"
"float w0;\n"
"float Ts;\n"
"float Vdc;\n"
"\n"
"// Control variables.\n"
"float a0; \n"
"float a1;\n"
"float a2; \n"
"float b1;\n"
"\n"
"float e1_alpha;\n"
"float e2_alpha;\n"
"float u_alpha;\n"
"float u1_alpha; \n"
"float u2_alpha;\n"
"\n"
"float e1_beta;\n"
"float e2_beta;\n"
"float u_beta;\n"
"float u1_beta; \n"
"float u2_beta;\n"
"\n"
"// Currents abc. \n"
"float ua; \n"
"float ub;\n"
"float uc;"
        Show          off
      }
      Parameter {
        Variable      "StartFcn"
        Value         "// Variables alpha.\n"
"e1_alpha = 0;\n"
"e2_alpha = 0;\n"
"u1_alpha = 0;\n"
"u2_alpha = 0;\n"
"\n"
"// Variables beta.\n"
"e1_beta = 0;\n"
"e2_beta = 0;\n"
"u1_beta = 0;\n"
"u2_beta = 0;"
        Show          off
      }
      Parameter {
        Variable      "OutputFcn"
        Value         "// Assign Parameters\n"
"e_alpha = em_alpha;\n"
"e_beta = em_beta;\n"
"\n"
"Kp = Kp_p;\n"
"Ki = Ki_p;\n"
"w0 = w0_p;\n"
"Ts = Ts_p; \n"
"Vdc = Vdc_p;\n"
"\n"
"// Control Action\n"
"a0 = Kp;\n"
"a1 = 2*((Ki/w0)*sin(w0*Ts) - Kp*cos(w0*Ts));\n"
"a2 = Kp - 2*Ki*sin(w0*Ts)/w0;\n"
"b1 = 2*cos(w0*Ts);\n"
"\n"
"u_alpha = a0*e_alpha + a1*e1_alpha + a2*e2_alpha + b1*u1_alpha - u2_alpha;\n"
"u_beta = a0*e_beta + a1*e1_beta + a2*e2_beta + b1*u1_beta - u2_beta;\n"
"\n"
"if (u_alpha >= Vdc){\n"
"\tu_alpha = Vdc;\n"
"\te_alpha = 0;\n"
"\te1_alpha = 0;\n"
"}\n"
"else if (u_alpha <= -Vdc){\n"
"\tu_alpha = -Vdc;\n"
"\te_alpha = 0;\n"
"\te1_alpha = 0;\n"
"}\n"
"\n"
"if (u_beta >= Vdc){\n"
"\tu_beta = Vdc;\n"
"\te_beta = 0;\n"
"\te1_beta = 0;\n"
"}\n"
"else if (u_beta <= -Vdc){\n"
"\tu_beta = -Vdc;\n"
"\te_beta = 0;\n"
"\te1_beta = 0;\n"
"}\n"
"\n"
"ua = u_alpha;\n"
"ub = -0.5*u_alpha + sqrt(3)*u_beta*0.5;\n"
"uc = -0.5*u_alpha - sqrt(3)*u_beta*0.5;\n"
"\n"
"OutputSignal(0,0) = ua;\n"
"OutputSignal(0,1) = ub;\n"
"OutputSignal(0,2) = uc;"
        Show          off
      }
      Parameter {
        Variable      "UpdateFcn"
        Value         "// Variables alpha.\n"
"e2_alpha = e1_alpha;\n"
"e1_alpha = e_alpha;\n"
"u2_alpha = u1_alpha; \n"
"u1_alpha = u_alpha;\n"
"\n"
"// Variables beta.\n"
"e2_beta = e1_beta;\n"
"e1_beta = e_beta;\n"
"u2_beta = u1_beta; \n"
"u1_beta = u_beta;"
        Show          off
      }
      Parameter {
        Variable      "DerivativeFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "TerminateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "StoreCustomStateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "RestoreCustomStateFcn"
        Value         ""
        Show          off
      }
    }
